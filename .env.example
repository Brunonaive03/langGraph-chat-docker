LLM_PROVIDER=ollama_cloud   # or 'gemini'

# --- OLLAMA CLOUD (No local install needed) ---
# Create key at: https://ollama.com/settings/keys
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_key
OLLAMA_CLOUD_MODEL=qwen3-coder:480b-cloud
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1

GOOGLE_API_KEY=your_gemini_key
GOOGLE_MODEL=gemini-3-flash-preview

LANGSMITH_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key
LANGSMITH_PROJECT=pokedex-cli